{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Usage",
  "version": "0.5.5",
  "identifier": "ai.vibecafe.vibe-usage.windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "popover",
        "title": "Vibe Usage",
        "url": "index.html",
        "width": 520,
        "height": 620,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "focus": true
      },
      {
        "label": "settings",
        "title": "Vibe Usage 设置",
        "url": "index.html",
        "width": 460,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/cli": "cli"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
