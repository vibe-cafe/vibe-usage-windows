{
  "name": "vibe-usage-app-windows",
  "private": true,
  "version": "0.5.10",
  "vibeUsageCliChannel": "latest",
  "type": "module",
  "description": "Vibe Usage for Windows — AI coding tool token usage tracker (Windows port of the macOS Vibe Usage app)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "vendor:cli": "node scripts/vendor-cli.mjs",
    "fetch:node": "node scripts/fetch-node.mjs",
    "check:version": "node scripts/check-version.mjs",
    "release:windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@tauri-apps/api": "^2.8.0",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
